      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "id": "http-detalhes",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nif (data.status === 'success' && data.data) {\n  const p = data.data;\n  const info = p.produtoLoja?.[0] || {};\n  const descHtml = info.descricao || '';\n  const descClean = descHtml.replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim().substring(0, 500);\n  \n  return [{ json: {\n    nome: p.nome,\n    modelo: p.modelo,\n    codigo: p.codigo,\n    marca_id: p.marca,\n    titulo: info.titulo,\n    complemento: info.tituloComplemento,\n    descricao: descClean,\n    acompanha: p.acompanha,\n    ativo: p.ativo,\n    palavras_chave: (p.palavraChave || '').substring(0, 200)\n  } }];\n}\n\nreturn [{ json: { erro: 'Produto não encontrado', dados: data } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 0],
      "id": "format-detalhes",
      "name": "Formatar Resposta"
    }
  ],
  "connections": {
