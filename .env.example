# ─────────────────────────────────────────────────────────────────────
# Chinelaria — env vars
# Copy to .env (and to apps/web/.env.local) and fill in real values.
# ─────────────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5
OPENAI_VISION_MODEL=gpt-5
OPENAI_WHISPER_MODEL=whisper-1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Magazord (Chinelaria Leilane Neves)
MAGAZORD_BASE_URL=https://chinelarialeilaneneves.painel.magazord.com.br
MAGAZORD_AUTH_BASIC=Basic TVpES2M5...

# Evolution API (WhatsApp)
EVOLUTION_BASE_URL=https://your-evolution-instance.example.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=chinelaria
EVOLUTION_WEBHOOK_SECRET=long-random-string-for-hmac

# MCP (loopback to local Next.js)
MCP_INTERNAL_URL=http://localhost:3000/api/mcp/sse
MCP_AUTH_TOKEN=long-random-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
